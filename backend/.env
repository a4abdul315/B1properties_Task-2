NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
MONGODB_URI=mongodb://127.0.0.1:27017/market_intelligence
CLIENT_ORIGIN=http://localhost:3000
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
NEWS_API_BASE_URL=https://newsapi.org/v2/everything
NEWS_API_KEY=replace_me
COMPETITOR_SCRAPE_SCHEDULE=*/20 * * * *
NEWS_INGESTION_SCHEDULE=*/30 * * * *
SOCIAL_SIMULATION_SCHEDULE=*/10 * * * *
INGESTION_REQUEST_TIMEOUT_MS=15000
INGESTION_RETRY_ATTEMPTS=3
INGESTION_RETRY_DELAY_MS=1500
ALERT_PRICE_DROP_THRESHOLD=5
ALERT_LISTING_SPIKE_THRESHOLD=10
ALERT_HEAT_INDEX_THRESHOLD=75
ALERT_EVALUATION_SCHEDULE=*/15 * * * *
REDIS_URL=redis://127.0.0.1:6379
REDIS_ENABLED=true
CACHE_ENABLED=true
INSIGHTS_CACHE_TTL_SECONDS=120
LISTINGS_CACHE_TTL_SECONDS=60
QUEUE_ENABLED=true
QUEUE_PREFIX=market-intelligence
INGESTION_QUEUE_NAME=ingestion-jobs
ALERT_QUEUE_NAME=alert-jobs
